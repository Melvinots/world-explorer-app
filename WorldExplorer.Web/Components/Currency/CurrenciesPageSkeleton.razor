
<MudCard Class="mb-6 pa-2" Elevation="0" Style="border: 1px solid var(--card-border); border-radius: 16px; width: 100%;">
    <MudCardContent Class="pa-6">
        <MudSkeleton SkeletonType="SkeletonType.Text" Width="180px" Height="32px" Class="mb-6" />
        <MudGrid Spacing="3">
            <MudItem xs="12" sm="3">
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="100%" Height="56px" Style="border-radius: 12px;" />
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="100%" Height="56px" Style="border-radius: 12px;" />
            </MudItem>
            <MudItem xs="12" sm="1" Class="d-flex align-center justify-center">
                <MudSkeleton SkeletonType="SkeletonType.Circle" Width="40px" Height="40px" />
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="100%" Height="56px" Style="border-radius: 12px;" />
            </MudItem>
            <MudItem xs="12" sm="2">
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="100%" Height="56px" Style="border-radius: 12px;" />
            </MudItem>
        </MudGrid>

        <MudPaper Class="mt-6 pa-6 d-flex flex-column align-center justify-center"
                  Elevation="0"
                  Style="border-radius: 16px; background: var(--nav-active-bg); border: 1px solid var(--card-border);">
            <MudSkeleton SkeletonType="SkeletonType.Text" Width="160px" Height="18px" Class="mb-2" />
            <MudSkeleton SkeletonType="SkeletonType.Text" Width="220px" Height="56px" Class="mb-2" />
            <MudSkeleton SkeletonType="SkeletonType.Text" Width="140px" Height="18px" />
        </MudPaper>
    </MudCardContent>
</MudCard>

<MudCard Class="pa-2" Elevation="0" Style="border: 1px solid var(--card-border); border-radius: 16px; width: 100%;">
    <MudCardHeader>
        <CardHeaderContent>
            <div class="d-flex align-center" style="gap: 8px;">
                <MudSkeleton SkeletonType="SkeletonType.Text" Width="140px" Height="24px" />
                <MudSkeleton SkeletonType="SkeletonType.Text" Width="70px" Height="16px" />
            </div>
        </CardHeaderContent>
    </MudCardHeader>
    <MudCardContent Class="pa-0 px-2">
        <MudSkeleton SkeletonType="SkeletonType.Rectangle"
                     Width="100%" Height="280px"
                     Style="border-radius: 12px;" />
    </MudCardContent>
</MudCard>