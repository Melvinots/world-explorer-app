@using ApexCharts
@using Size = MudBlazor.Size
@using Color = MudBlazor.Color
@using Align = MudBlazor.Align

<MudCard Class="pa-2" Elevation="0" Style="border: 1px solid var(--card-border); border-radius: 16px; width: 100%;">
    <MudCardHeader>
        <CardHeaderContent>
            <MudText Typo="Typo.h6" Style="font-weight: 600; letter-spacing: -0.5px; color: var(--text-heading);">
                Historical Rates
                <MudText Typo="Typo.caption" Style="color: var(--text-muted); margin-left: 8px;">
                    Past 1 Year
                </MudText>
            </MudText>
        </CardHeaderContent>
    </MudCardHeader>
    <MudCardContent Class="pa-0 px-2">
        @if (_isLoadingChart)
        {
            <MudSkeleton SkeletonType="SkeletonType.Rectangle"
                         Width="100%" Height="280px"
                         Style="border-radius: 12px;" />
        }
        else if (_dataPoints.Any())
        {
            <div style="width: 100%; overflow: hidden;">
                <ApexChart TItem="RateDataPoint"
                           Title="@($"{FromCurrency} to {ToCurrency}")"
                           Options="_chartOptions"
                           Height="280">
                    <ApexPointSeries TItem="RateDataPoint"
                                     Items="_dataPoints"
                                     SeriesType="SeriesType.Line"
                                     Name="@($"{FromCurrency}/{ToCurrency}")"
                                     XValue="@(e => e.Date.ToString("yyyy-MM-dd"))"
                                     YValue="@(e => (decimal)e.Rate)" />
                </ApexChart>
            </div>
        }
        else
        {
            <div class="d-flex flex-column align-center justify-center py-12" style="gap: 8px;">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                     fill="none" stroke="var(--text-muted)" stroke-width="1.5"
                     stroke-linecap="round" stroke-linejoin="round"
                     style="width: 40px; height: 40px;">
                    <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
                </svg>
                <MudText Align="Align.Center" Style="color: var(--text-muted);">
                    Convert a currency pair to load the chart
                </MudText>
            </div>
        }
    </MudCardContent>
</MudCard>