@page "/countries"

@namespace WorldExplorer.Web.Pages
@attribute [StreamRendering]

<PageTitle>Countries</PageTitle>

<div class="dashboard-header">
    <div class="title-row">
        <svg class="globe-icon"  xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="1.8"
             stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10" />
            <line x1="2" y1="12" x2="22" y2="12" />
            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
        </svg>
        <h1 class="dashboard-title">World Countries</h1>
    </div>

    <p class="dashboard-subtitle">
        Explore information about @TotalCount countries worldwide. Click on any country to view detailed information.
    </p>

    <div class="search-row">
        <SearchBox Value="@_searchText"
                   Placeholder="Search countries or capitals..."
                   ValueChanged="OnSearchChanged" />
        <RegionFilter @bind-SelectedRegion="_selectedRegion" />
    </div>

    <span class="showing-label">
        Showing @FilteredCount countries
    </span>

    <div class="country-grid">
        @if (_isLoading)
        {
            @for (int i = 0; i < 12; i++)
            {
                <div class="skeleton-card">
                    <div class="skeleton-header">
                        <div class="skeleton-box small"></div>
                        <div class="skeleton-box medium"></div>
                    </div>
                    <div class="skeleton-box thin"></div>
                    <div class="skeleton-box tiny"></div>
                </div>
            }
        }
        else if (FilteredCountries is null || !FilteredCountries.Any())
        {
            <div class="empty-state">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="1.5"
                         stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8"/>
                        <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                        <line x1="8" y1="11" x2="14" y2="11"/>
                    </svg>
                    <p class="empty-title">No countries found</p>
                    <p class="empty-subtitle">Try adjusting your search or filter</p>
                </div>
        }
        else
        {
            @foreach (var country in FilteredCountries)
            {
                <CountryCard CountryCode="@country.Cca2"
                             CountryName="@country.Name?.Common"
                             Capital="@country.Capital?.FirstOrDefault()"
                             Region="@country.Region"
                             Population="@FormatHelper.FormatPopulation(country.Population)"
                             OnClick="() => OnCardClicked(country.Name?.Common ?? string.Empty)" />
            }
        }
        <CountryModal @ref="_modal" />
    </div>
    <ScrollToTop />
</div>


