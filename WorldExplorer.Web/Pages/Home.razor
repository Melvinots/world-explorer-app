@page "/"
@namespace WorldExplorer.Web.Pages

<PageTitle>WorldExplorer — Explore the World & Beyond</PageTitle>

<div class="home">

    <!-- Hero -->
    <section class="hero">
        <div class="hero-bg">
            <div class="orb orb-1"></div>
            <div class="orb orb-2"></div>
            <div class="orb orb-3"></div>
        </div>
        <div class="hero-content">
            <div class="hero-badge">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="1.8"
                     stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10" />
                    <polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76" />
                </svg>
                <span>WorldExplorer</span>
            </div>
            <h1 class="hero-title">
                Explore the<br />
                <span class="hero-accent">World &amp; Beyond</span>
            </h1>
            <p class="hero-subtitle">
                Your gateway to exploring everything — from nations and cultures
                to geography, nature, and the universe itself.
            </p>
            <div class="hero-actions">
                <a href="/countries" class="btn-primary">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8" />
                        <line x1="21" y1="21" x2="16.65" y2="16.65" />
                    </svg>
                    Explore Countries
                </a>
            </div>
        </div>
    </section>

    <!-- Stats -->
    <section class="stats">
        <div class="stat-card">
            <span class="stat-number">250+</span>
            <span class="stat-label">Countries</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-card">
            <span class="stat-number">7</span>
            <span class="stat-label">Continents</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-card">
            <span class="stat-number">8B+</span>
            <span class="stat-label">People</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-card">
            <span class="stat-number">1</span>
            <span class="stat-label">Universe</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-card">
            <span class="stat-number">&#8734;</span>
            <span class="stat-label">Topics</span>
        </div>
    </section>

    <!-- Features -->
    <section class="features">
        <h2 class="features-title">Start exploring today</h2>
        <div class="features-grid">

            <!-- Available -->
            <div class="feature-card">
                <div class="feature-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="1.8"
                         stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10" />
                        <line x1="2" y1="12" x2="22" y2="12" />
                        <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                    </svg>
                </div>
                <h3 class="feature-title">Countries</h3>
                <p class="feature-desc">Explore 250+ countries — capitals, populations, currencies, languages, flags and more.</p>
                <a href="/countries" class="feature-link">
                    Explore now
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round">
                        <line x1="5" y1="12" x2="19" y2="12" />
                        <polyline points="12 5 19 12 12 19" />
                    </svg>
                </a>
            </div>

            <!-- Coming Soon -->
            <div class="feature-card coming-soon">
                <div class="feature-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="1.8"
                         stroke-linecap="round" stroke-linejoin="round">
                        <polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6" />
                        <line x1="8" y1="2" x2="8" y2="18" />
                        <line x1="16" y1="6" x2="16" y2="22" />
                    </svg>
                </div>
                <h3 class="feature-title">Geography</h3>
                <p class="feature-desc">Mountains, rivers, oceans, deserts and the natural wonders of our planet.</p>
                <span class="badge-soon">Coming Soon</span>
            </div>

            <div class="feature-card coming-soon">
                <div class="feature-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="1.8"
                         stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10" />
                        <circle cx="12" cy="12" r="3" />
                        <line x1="12" y1="2" x2="12" y2="5" />
                        <line x1="12" y1="19" x2="12" y2="22" />
                        <line x1="2" y1="12" x2="5" y2="12" />
                        <line x1="19" y1="12" x2="22" y2="12" />
                    </svg>
                </div>
                <h3 class="feature-title">Universe</h3>
                <p class="feature-desc">Planets, stars, galaxies and the mysteries of space exploration.</p>
                <span class="badge-soon">Coming Soon</span>
            </div>

            <div class="feature-card coming-soon">
                <div class="feature-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="1.8"
                         stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                    </svg>
                </div>
                <h3 class="feature-title">Nature</h3>
                <p class="feature-desc">Wildlife, ecosystems, biodiversity and the forces that shape our natural world.</p>
                <span class="badge-soon">Coming Soon</span>
            </div>

            <div class="feature-card coming-soon">
                <div class="feature-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="1.8"
                         stroke-linecap="round" stroke-linejoin="round">
                        <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" />
                        <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
                    </svg>
                </div>
                <h3 class="feature-title">History</h3>
                <p class="feature-desc">Ancient civilizations, world events and the stories that shaped humanity.</p>
                <span class="badge-soon">Coming Soon</span>
            </div>

            <div class="feature-card coming-soon">
                <div class="feature-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="1.8"
                         stroke-linecap="round" stroke-linejoin="round">
                        <path d="M18 20V10" />
                        <path d="M12 20V4" />
                        <path d="M6 20v-6" />
                    </svg>
                </div>
                <h3 class="feature-title">Statistics</h3>
                <p class="feature-desc">Global data, rankings and trends across economics, health and society.</p>
                <span class="badge-soon">Coming Soon</span>
            </div>

        </div>
    </section>

    <!-- CTA -->
    <section class="cta">
        <div class="cta-content">
            <h2 class="cta-title">Start your journey</h2>
            <p class="cta-subtitle">Begin with countries — more topics coming soon.</p>
            <a href="/countries" class="btn-primary">
                Get Started
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12" />
                    <polyline points="12 5 19 12 12 19" />
                </svg>
            </a>
        </div>
    </section>

</div>
