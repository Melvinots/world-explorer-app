@page "/currencies"

@using Size = MudBlazor.Size
@using Color = MudBlazor.Color
@using Align = MudBlazor.Align
@using Variant = MudBlazor.Variant

<PageTitle>Currency Converter</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Currency Converter</MudText>

@if (_isLoadingCurrencies)
{
    <MudProgressLinear Indeterminate="true" Class="mb-4" />
}
else
{
    @* ─── Converter Card ─── *@
    <MudCard Class="mb-6">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h6">Convert</MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            <MudGrid>
                <MudItem xs="12" sm="3">
                    <MudNumericField @bind-Value="_amount"
                                     Label="Amount"
                                     Variant="Variant.Outlined"
                                     Min="0"
                                     Format="F2"
                                     FullWidth="true" />
                </MudItem>
                <MudItem xs="12" sm="3">
                    <MudSelect @bind-Value="_fromCurrency"
                               Label="From"
                               Variant="Variant.Outlined"
                               FullWidth="true">
                        @foreach (var currency in _currencies)
                        {
                            <MudSelectItem Value="@currency.Code">@currency.ToString()</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="1" Class="d-flex align-center justify-center">
                    <MudIconButton Icon="@Icons.Material.Filled.SwapHoriz"
                                   Color="Color.Primary"
                                   OnClick="SwapCurrencies" />
                </MudItem>
                <MudItem xs="12" sm="3">
                    <MudSelect @bind-Value="_toCurrency"
                               Label="To"
                               Variant="Variant.Outlined"
                               FullWidth="true">
                        @foreach (var currency in _currencies)
                        {
                            <MudSelectItem Value="@currency.Code">@currency.ToString()</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="2" Class="d-flex align-center">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               OnClick="ConvertAsync"
                               Disabled="_isConverting">
                        @if (_isConverting)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                        }
                        else
                        {
                            <span>Convert</span>
                        }
                    </MudButton>
                </MudItem>
            </MudGrid>

            @if (_conversionResult is not null)
            {
                <MudDivider Class="my-4" />
                <MudText Typo="Typo.h5" Align="Align.Center">
                    @_amount.ToString("F2") @_fromCurrency
                    <MudText Typo="Typo.h5" Inline="true" Color="Color.Secondary">=</MudText>
                    @_conversionResult.ConvertedAmount.ToString("F4") @_toCurrency
                </MudText>
                <MudText Typo="Typo.caption" Align="Align.Center" Class="mt-1" Color="Color.Default">
                    Rate as of @_conversionResult.Date
                </MudText>
            }
        </MudCardContent>
    </MudCard>

    @* ─── Historical Chart Card ─── *@
    <MudCard>
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h6">Historical Rates</MudText>
            </CardHeaderContent>
            <CardHeaderActions>
                <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small">
                    @foreach (var range in _dateRanges)
                    {
                        <MudButton Color="@(_selectedRange == range.Key ? Color.Primary : Color.Default)"
                                   OnClick="() => SelectRangeAsync(range.Key)">
                            @range.Key
                        </MudButton>
                    }
                </MudButtonGroup>
            </CardHeaderActions>
        </MudCardHeader>
        <MudCardContent>
            @if (_isLoadingChart)
            {
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="300px" />
            }
            else if (_dataPoints.Any())
            {
                <ApexChart TItem="RateDataPoint"
                           Title="@($"{_fromCurrency} to {_toCurrency}")"
                           Options="_chartOptions">
                    <ApexPointSeries TItem="RateDataPoint"
                                     Items="_dataPoints"
                                     SeriesType="SeriesType.Line"
                                     Name="@($"{_fromCurrency}/{_toCurrency}")"
                                     XValue="@(e => e.Date.ToString("yyyy-MM-dd"))"
                                     YValue="@(e => (decimal)e.Rate)" />
                </ApexChart>
            }
            else
            {
                <MudText Align="Align.Center" Color="Color.Default" Class="py-8">
                    Select currencies and convert to load the chart.
                </MudText>
            }
        </MudCardContent>
    </MudCard>
}