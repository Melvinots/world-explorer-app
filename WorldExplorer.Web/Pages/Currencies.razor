@page "/currencies"

@inherits ThemeAwareComponent
@attribute [StreamRendering]
@namespace WorldExplorer.Web.Pages

<PageTitle>Currency Converter</PageTitle>

@if (_isLoadingCurrencies)
{
    <CurrenciesPageSkeleton />
}
else
{
    <CurrencyConverter Currencies="_currencies" OnConverted="HandleConverted" OnReset="HandleReset" />
    <CurrencyChart @ref="_chart" />
}